# Backend runtime env (used when running `npm run dev` inside the backend/ folder)
API_PORT=8080

# When running the API locally (not inside Docker), Postgres is exposed on localhost via docker compose
DATABASE_URL=postgres://taskflow:taskflow@localhost:5432/taskflow

# Used to sign/verify JWTs. Must be at least 16 characters.
JWT_SECRET=change-me-please-use-at-least-16-chars
