# PostgreSQL
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_password

# Spring Boot datasource (used by API container)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/taskflow
SPRING_DATASOURCE_USERNAME=taskflow
SPRING_DATASOURCE_PASSWORD=taskflow_password

# JWT — MUST be changed in production (min 32 chars)
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING  # e.g. openssl rand -hex 32

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend API URL (baked into React build at docker compose build time)
VITE_API_URL=http://localhost:8080

