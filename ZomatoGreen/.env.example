# PostgreSQL
POSTGRES_DB=gims
POSTGRES_USER=gims_user
POSTGRES_PASSWORD=gims_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://gims_user:gims_secret@postgres:5432/gims?sslmode=disable

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# Service URLs (internal Docker network)
GATEWAY_PORT=8000
MANAGEMENT_SERVICE_URL=http://management:8001
GEOSPATIAL_SERVICE_URL=http://geospatial:8002
TELEMETRY_SERVICE_URL=http://telemetry:8003
CARBON_SERVICE_URL=http://carbon:8004

# Redis
REDIS_URL=redis://redis:6379

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_TELEMETRY=telemetry.events

# Seed user credentials
SEED_USER_EMAIL=test@example.com
SEED_USER_PASSWORD=password123
