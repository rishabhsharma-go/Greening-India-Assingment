{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-4a5b-b6c7-d8e9f0a1b2c3",
		"name": "TaskFlow Elite - Premium API Suite",
		"description": "**Enterprise-Grade API Suite** for TaskFlow Elite.\n\n### 🛡️ Secure Contexts\nThis collection is logically divided into **Perspectives**:\n- **01. Authentication**: Identity Manifestation.\n- **02. User Workspace**: Core Task management (Projects/Tasks).\n- **03. Admin Moderation**: Restricted analytical endpoints.\n\n### ⚡ Automatic Auth\nThe login request contains a script to sync your `bearer_token` automatically. No manual copy-pasting required.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "00. System Infrastructure",
			"item": [
				{
					"name": "Health Heartbeat (Public)",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"health"
							]
						},
						"description": "Public infrastructure signal to verify API vitality without authentication."
					},
					"response": []
				}
			]
		},
		{
			"name": "01. Auth & Identity",
			"item": [
				{
					"name": "Register (New User)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Ecologist Jane\",\n    \"email\": \"jane@taskflow.com\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"register"
							]
						},
						"description": "Registers a new standard user in the elite ecosystem."
					},
					"response": []
				},
				{
					"name": "Login (Admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (pm.response.code === 201 || pm.response.code === 200) {",
									"    pm.environment.set(\"bearer_token\", jsonData.token);",
									"    console.log(\"✔ Bearer Token Synced Successfully\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Authenticates an administrator and captures the Bearer token."
					},
					"response": []
				},
				{
					"name": "Guardians Discovery (Lattice Registry)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/users",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users"
							]
						},
						"description": "Retrieves the full registry of synchronized nodes (guardians) from the ecosystem lattice."
					},
					"response": []
				}
			]
		},
